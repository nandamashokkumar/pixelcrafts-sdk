{
  "name": "@pixelcrafts/auth",
  "version": "0.1.0",
  "description": "Web SDK for the pixelcrafts central auth gateway (auth.pixelcrafts.app). Firebase + Next.js + React.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pixelcrafts-app/pixelcrafts-sdk",
    "directory": "web/auth"
  },
  "keywords": [
    "pixelcrafts",
    "auth",
    "firebase",
    "nextjs",
    "react",
    "jwt"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "firebase": "^10.0.0 || ^11.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "firebase": "^11.0.0",
    "next": "^14.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
